# ============================================================
# TS Discord Bridge Beta
# Copy this file to .env and fill in your own values.
# ============================================================

# ------------------------------------------------------------
# Beta license
# ------------------------------------------------------------
BRIDGE_LICENSE_KEY=beta-local-test-001
BRIDGE_LICENSE_CHECK_INTERVAL_MS=43200000
BRIDGE_LICENSE_TOLERATED_FAILURES=1
BRIDGE_LICENSE_CACHE_FILE=/data/license-state.json
BRIDGE_VERSION=4.5.6-beta

# ------------------------------------------------------------
# Discord
# ------------------------------------------------------------
DISCORD_TOKEN=CHANGE_ME
DISCORD_GUILD_ID=CHANGE_ME
DISCORD_STATUS_CHANNEL_ID=CHANGE_ME

# ------------------------------------------------------------
# TeamSpeak
# ------------------------------------------------------------
TS_HOST=CHANGE_ME
TS_PORT=30012
TS_NICKNAME=DiscordBridge
TS_CHANNEL_ID=CHANGE_ME
TS_PASSWORD=CHANGE_ME
TS_CHANNEL_PASSWORD=

# ------------------------------------------------------------
# TeamSpeak WebQuery
# ------------------------------------------------------------
TS_WEBQUERY_ENABLED=true
TS_WEBQUERY_HOST=CHANGE_ME
TS_WEBQUERY_PORT=30036
TS_WEBQUERY_PROTOCOL=http
TS_WEBQUERY_SERVER_ID=1
TS_WEBQUERY_API_KEY=CHANGE_ME
TS_WEBQUERY_CACHE_MS=300000

# ------------------------------------------------------------
# Bridge behavior
# ------------------------------------------------------------
DATA_DIR=/data
ENABLE_DISCORD_TO_TS=1
ENABLE_TS_TO_DISCORD=1
AUTO_RULES_ACCEPT=1
BRIDGE_AUTO_LEAVE_MS=300000
BRIDGE_REGISTRY_FILE=/data/bridge-registered-users.json

# ------------------------------------------------------------
# Audio ports
# Usually do not change these unless they conflict.
# ------------------------------------------------------------
USE_RUST_AUDIO_SIDECAR=true
RUST_SIDECAR_HOST=127.0.0.1
RUST_SIDECAR_PORT=41000
NODE_PCM_LISTEN_PORT=41001
DC_TO_TS_SIDECAR_HOST=127.0.0.1
DC_TO_TS_SIDECAR_PORT=41002
NODE_TS_OPUS_LISTEN_PORT=41003

# ------------------------------------------------------------
# Audio tuning
# ------------------------------------------------------------
DISCORD_PCM_RINGBUFFER_FRAMES=50
DISCORD_TO_TS_GAIN=0.85
DISCORD_TO_TS_MAX_QUEUE_FRAMES=8
DISCORD_TO_TS_STALE_MS=1500
SIDECAR_INPUT_CHANNEL_CAPACITY=256

# ------------------------------------------------------------
# Logging
# ------------------------------------------------------------
BRIDGE_HEALTH_LOG_MS=0
BRIDGE_DEBUG_LOGS=0
DEBUG_LOGS=0
SIDECAR_LOG_INTERVAL_MS=0
SIDECAR_STARTUP_LOGS=0
